{
  "profiles": [
    {
      "name": "Default profile",
      "selected": true,
      "simple_modifications": [
        { "from": { "key_code": "caps_lock" }, "to": [{ "key_code": "left_control" }] }
      ],
      "complex_modifications": {
        "rules": [
          {
            "description": "共通設定: 全キーボード共通のカーソル移動",
            "manipulators": [
              { "type": "basic", "from": { "key_code": "f", "modifiers": { "mandatory": ["left_control"] } }, "to": [{ "key_code": "right_arrow" }] },
              { "type": "basic", "from": { "key_code": "b", "modifiers": { "mandatory": ["left_control"] } }, "to": [{ "key_code": "left_arrow" }] },
              { "type": "basic", "from": { "key_code": "p", "modifiers": { "mandatory": ["left_control"] } }, "to": [{ "key_code": "up_arrow" }] },
              { "type": "basic", "from": { "key_code": "n", "modifiers": { "mandatory": ["left_control"] } }, "to": [{ "key_code": "down_arrow" }] }
            ]
          },
          {
            "description": "デバイス別設定リスト",
            "manipulators": [
              /* --- 【キーボードAとBのみ共通】: 右CtrlをCmd化 --- */
              { "type": "basic", "from": { "key_code": "right_control" }, "to": [{ "key_code": "right_command" }], "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 111, "product_id": 222 }, { "vendor_id": 1111, "product_id": 2222 }] }] },

              /* --- 【キーボードAのみ】: 右ShiftをEnter化 --- */
              { "type": "basic", "from": { "key_code": "right_shift", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "right_shift" }], "to_if_alone": [{ "key_code": "return_or_enter" }], "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1452, "product_id": 654 }] }] },

              /* --- 【キーボードCのみ】: 特殊マッピング (例: OptionをMission Controlに) --- */
              { "type": "basic", "from": { "key_code": "right_option" }, "to": [{ "key_code": "mission_control" }], "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 3333, "product_id": 4444 }] }] }
            ]
          }
        ]
      },
      "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
    }
  ]
}